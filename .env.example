# ──────────────────────────────────────────────
#  ODONT HUB — Variáveis de Ambiente
#  Copie para .env e preencha os valores reais
# ──────────────────────────────────────────────

# SERVIDOR
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# SUPABASE (banco PostgreSQL)
# Crie em: https://supabase.com → New Project
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:[senha]@db.xxxx.supabase.co:5432/postgres

# REDIS — Upstash (cache + sessões + pub/sub)
# Crie em: https://upstash.com → Create Database → Redis
REDIS_URL=rediss://default:senha@xxxx.upstash.io:6379

# CLOUDFLARE R2 (armazenamento de mídia)
# Crie em: Cloudflare Dashboard → R2 → Create Bucket
R2_ACCOUNT_ID=xxxx
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=odont-hub-media
R2_PUBLIC_URL=https://media.odont-hub.com.br

# E-MAIL — Resend (transacional)
# Crie em: https://resend.com → Add API Key
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@odont-hub.com.br

# WHATSAPP (opcional para MVP — usar deep link wa.me/)
# Meta Business API: https://developers.facebook.com
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
